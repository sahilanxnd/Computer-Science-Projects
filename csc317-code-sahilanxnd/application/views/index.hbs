<main>
  {{#if messages.success}}
  <div class="alert alert-success">
    {{#each messages.success}}<p>{{this}}</p>{{/each}}
  </div>
  {{/if}}

  {{#if messages.error}}
  <div class="alert alert-danger">
    {{#each messages.error}}<p>{{this}}</p>{{/each}}
  </div>
  {{/if}}

  <div class="welcome-banner">
    {{#if user}}
    <h2>Welcome back, {{user.username}} 👋</h2>
    <p>Here's what's been posted lately.</p>
    {{else}}
    <h2>Discover Videos</h2>
    <p><a href="/users/login" style="color:var(--accent);text-decoration:underline;">Log in</a> or <a href="/users/registration" style="color:var(--accent2);text-decoration:underline;">register</a> to post your own.</p>
    {{/if}}
  </div>

  <p class="section-heading">Latest Posts</p>

  {{#if posts.length}}
  <div class="video-grid">
    {{#each posts}}
    <div class="video-card">
      <a href="/posts/{{post_id}}">
        {{#if thumbnail}}
        <img src="/public/{{thumbnail}}" alt="{{title}}" class="video-card-thumb">
        {{else}}
        <div class="video-card-thumb-placeholder">▶</div>
        {{/if}}
        <div class="video-card-body">
          <p class="video-card-title">{{title}}</p>
          <p class="video-card-meta">by {{username}}</p>
        </div>
      </a>
    </div>
    {{/each}}
  </div>
  {{else}}
  <div class="empty-state">
    <span class="empty-icon">🎬</span>
    <p>No videos yet. Be the first to post!</p>
    <a href="/posts/postvideo">Upload a Video</a>
  </div>
  {{/if}}
</main>