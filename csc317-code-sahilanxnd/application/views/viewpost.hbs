<main>
  <div class="post-container">

    {{#if post}}

    <div class="post-header">
      <h1 class="post-title">{{post.title}}</h1>
      <div class="post-meta">
        <span>👤 {{post.username}}</span>
        <span>🕐 {{post.created_at}}</span>
      </div>
    </div>

    <div class="post-video-wrap">
      <video src="/public/videos/{{post.videoFile}}" controls>
        Your browser does not support the video tag.
      </video>
    </div>

    {{#if post.description}}
    <div class="post-description">{{post.description}}</div>
    {{/if}}

    {{#if user}}
    <div class="like-bar">
      {{#if post.hasLiked}}
      <form action="/posts/{{post.post_id}}/unlike" method="POST" style="margin:0;">
        <button type="submit" class="btn-unlike">👎 Unlike</button>
      </form>
      {{else}}
      <form action="/posts/{{post.post_id}}/like" method="POST" style="margin:0;">
        <button type="submit" class="btn-like">👍 Like</button>
      </form>
      {{/if}}
      <span class="like-count">{{post.likeCount}} {{#if post.likeCount}}likes{{else}}like{{/if}}</span>
    </div>
    {{else}}
    <p class="login-prompt"><a href="/users/login">Log in</a> to like this video.</p>
    {{/if}}

    <div class="comments-section">
      <h3>Comments</h3>

      {{#if user}}
      <div class="comment-form">
        <form action="/posts/{{post.post_id}}/comment" method="POST">
          <textarea name="comment" rows="3" placeholder="Write a comment..." required></textarea>
          <button type="submit">Post Comment</button>
        </form>
      </div>
      {{else}}
      <div class="login-prompt">
        <a href="/users/login">Log in</a> to leave a comment.
      </div>
      {{/if}}

      <ul class="comment-list">
        {{#each post.comments}}
        <li class="comment-item">
          <div class="comment-author">{{this.username}}</div>
          <div class="comment-date">{{this.created_at}}</div>
          <div class="comment-content">{{this.content}}</div>
        </li>
        {{else}}
        <li class="empty-state" style="padding:40px 0;">
          <span class="empty-icon">💬</span>
          <p>No comments yet. Be the first!</p>
        </li>
        {{/each}}
      </ul>
    </div>

    {{else}}

    <div class="empty-state">
      <span class="empty-icon">🎬</span>
      <p>No post selected. Browse videos from the home page.</p>
      <a href="/">Go Home</a>
    </div>

    {{/if}}

  </div>
</main>